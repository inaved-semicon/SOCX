    -waveform [list 0 [expr $CLK1_PERIOD/2]] \
    [get_ports REF_CLK]
@file(cons.tcl) 30: set_clock_uncertainty \
    -setup $CLK_SETUP_SKEW \
    [get_clocks $CLK1]
@file(cons.tcl) 34: set_clock_uncertainty \
    -hold $CLK_HOLD_SKEW \
    [get_clocks $CLK1]
@file(cons.tcl) 38: create_clock \
    -name $CLK2 \
    -period $CLK2_PERIOD \
    -waveform [list 0 [expr $CLK2_PERIOD/2]] \
    [get_ports UART_CLK]
@file(cons.tcl) 44: set_clock_uncertainty \
    -setup $CLK_SETUP_SKEW \
    [get_clocks $CLK2]
@file(cons.tcl) 48: set_clock_uncertainty \
    -hold $CLK_HOLD_SKEW \
    [get_clocks $CLK2]
@file(cons.tcl) 57: create_generated_clock \
    -name UART_RX_CLK \
    -source [get_ports UART_CLK] \
    -divide_by 1 \
    [get_pins U1_Integer_Clock_Divider_RX/o_div_clk]
@file(cons.tcl) 63: set_clock_uncertainty \
    -setup $CLK_SETUP_SKEW \
    [get_clocks UART_RX_CLK]
@file(cons.tcl) 67: set_clock_uncertainty \
    -hold $CLK_HOLD_SKEW \
    [get_clocks UART_RX_CLK]
@file(cons.tcl) 72: create_generated_clock \
    -name UART_TX_CLK \
    -source [get_ports UART_CLK] \
    -divide_by 32 \
    [get_pins U0_Integer_Clock_Divider_TX/o_div_clk]
@file(cons.tcl) 78: set_clock_uncertainty \
    -setup $CLK_SETUP_SKEW \
    [get_clocks UART_TX_CLK]
@file(cons.tcl) 82: set_clock_uncertainty \
    -hold $CLK_HOLD_SKEW \
    [get_clocks UART_TX_CLK]
@file(cons.tcl) 87: create_generated_clock \
    -name ALU_CLK \
    -source [get_ports REF_CLK] \
    -divide_by 1 \
    -combinational \
    [get_pins U0_CLK_GATE/GATED_CLK]
@file(cons.tcl) 94: set_clock_uncertainty \
    -setup $CLK_SETUP_SKEW \
    [get_clocks ALU_CLK]
@file(cons.tcl) 98: set_clock_uncertainty \
    -hold $CLK_HOLD_SKEW \
    [get_clocks ALU_CLK]
@file(cons.tcl) 106: set_clock_groups \
    -asynchronous \
    -group [get_clocks {REF_CLK ALU_CLK}] \
    -group [get_clocks {UART_CLK UART_TX_CLK UART_RX_CLK}]
@file(cons.tcl) 115: set in2_delay  [expr 0.2*$CLK2_PERIOD]
@file(cons.tcl) 116: set out2_delay [expr 0.2*$CLK2_PERIOD]
@file(cons.tcl) 118: set in1_delay  [expr 0.2*$CLK1_PERIOD]
@file(cons.tcl) 119: set out1_delay [expr 0.2*$CLK1_PERIOD]
